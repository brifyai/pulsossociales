# Supabase Environment Variables
# Copy this file to .env and fill in the values

# Database
POSTGRES_PASSWORD=your-super-secret-postgres-password
POSTGRES_DB=postgres
POSTGRES_USER=postgres

# Supavisor (Connection Pooler)
POOLER_PROXY_PORT_TRANSACTION=6543
POOLER_DEFAULT_POOL_SIZE=20
POOLER_MAX_CLIENT_CONN=100

# Auth (GoTrue)
GOTRUE_JWT_SECRET=your-super-secret-jwt-secret
GOTRUE_JWT_EXP=3600
GOTRUE_JWT_AUD=authenticated
GOTRUE_JWT_DEFAULT_GROUP_NAME=authenticated

# Disable external providers by default
GOTRUE_EXTERNAL_GOOGLE_ENABLED=false
GOTRUE_EXTERNAL_GOOGLE_CLIENT_ID=
GOTRUE_EXTERNAL_GOOGLE_SECRET=
GOTRUE_EXTERNAL_GOOGLE_REDIRECT_URI=

# SMTP Settings (optional)
GOTRUE_SMTP_HOST=
GOTRUE_SMTP_PORT=
GOTRUE_SMTP_USER=
GOTRUE_SMTP_PASS=
GOTRUE_SMTP_ADMIN_EMAIL=

# Site URL
GOTRUE_SITE_URL=http://localhost:3000
GOTRUE_URI_ALLOW_LIST=""
GOTRUE_DISABLE_SIGNUP=false

# API
GOTRUE_API_HOST=0.0.0.0

# Realtime
REALTIME_DEFAULT_TENANT=realtime-dev
REALTIME_DEFAULT_API_KEY=your-super-secret-api-key

# Storage
STORAGE_BACKEND=file
STORAGE_S3_BUCKET=supabase-storage
STORAGE_S3_ENDPOINT=
STORAGE_S3_REGION=us-east-1
STORAGE_S3_ACCESS_KEY_ID=
STORAGE_S3_SECRET_ACCESS_KEY=

# Analytics
LOGFLARE_LOGGER_BACKEND_API_KEY=
LOGFLARE_SINGLE_TENANT=true
LOGFLARE_SUPABASE_MODE=true

# Studio
STUDIO_DEFAULT_ORGANIZATION=Default Organization
STUDIO_DEFAULT_PROJECT=Default Project
STUDIO_PORT=3000
SUPABASE_PUBLIC_URL=http://localhost:8000

# Kong
KONG_DATABASE=off
KONG_DECLARATIVE_CONFIG=/home/kong/kong.yml
KONG_DNS_ORDER=LAST,A,CNAME

# Imgproxy
IMGPROXY_KEY=your-super-secret-imgproxy-key
IMGPROXY_SALT=your-super-secret-imgproxy-salt
IMGPROXY_LOCAL_FILESYSTEM_ROOT=/tmp

# Functions
FUNCTIONS_VERIFY_JWT=false
